!.yarn/plugins
!.yarn/releases
!.yarn/versions

/coverage
/.next/
/out/
/build

.DS_Store
*.pem

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

.env*

.vercel
.netlify/
*.tsbuildinfo
next-env.d.ts
